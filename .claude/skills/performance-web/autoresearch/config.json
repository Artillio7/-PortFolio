{
  "skill_name": "performance-web",
  "skill_md_path": ".claude/skills/performance-web/SKILL.md",
  "description": "Optimize PortFolio load time and runtime performance via iterative configuration testing",
  "method": "cli",
  "cycle_seconds": 180,
  "max_prompt_words": 800,
  "scenarios": [
    {
      "id": "S01_desktop_first_load",
      "description": "Desktop first visit, no cache, 4G connection",
      "config": {
        "starCount": 250,
        "nebulaCount": 3,
        "enableConstellations": true,
        "enableNebulae": true,
        "shootingStarInterval": 6000,
        "scripts_defer": true
      }
    },
    {
      "id": "S02_mobile_first_load",
      "description": "Mobile first visit, 3G connection, low GPU",
      "config": {
        "starCount": 120,
        "nebulaCount": 2,
        "enableConstellations": false,
        "enableNebulae": false,
        "shootingStarInterval": 8000,
        "scripts_defer": true
      }
    },
    {
      "id": "S03_desktop_minimal",
      "description": "Desktop with minimal particles for max speed",
      "config": {
        "starCount": 100,
        "nebulaCount": 1,
        "enableConstellations": false,
        "enableNebulae": false,
        "shootingStarInterval": 10000,
        "scripts_defer": true
      }
    },
    {
      "id": "S04_desktop_rich",
      "description": "Desktop with rich visuals, balance perf/aesthetics",
      "config": {
        "starCount": 300,
        "nebulaCount": 4,
        "enableConstellations": true,
        "enableNebulae": true,
        "shootingStarInterval": 5000,
        "scripts_defer": true
      }
    },
    {
      "id": "S05_mobile_ultra_light",
      "description": "Mobile with bare minimum for fastest FCP",
      "config": {
        "starCount": 60,
        "nebulaCount": 0,
        "enableConstellations": false,
        "enableNebulae": false,
        "enableMouseInteraction": false,
        "shootingStarInterval": 15000,
        "scripts_defer": true
      }
    },
    {
      "id": "S06_tablet_balanced",
      "description": "Tablet with balanced config",
      "config": {
        "starCount": 180,
        "nebulaCount": 2,
        "enableConstellations": true,
        "enableNebulae": false,
        "shootingStarInterval": 7000,
        "scripts_defer": true
      }
    },
    {
      "id": "S07_reduced_motion",
      "description": "User prefers reduced motion - static frame only",
      "config": {
        "starCount": 150,
        "reducedMotion": true,
        "enableConstellations": false,
        "enableNebulae": false,
        "enableShootingStars": false,
        "scripts_defer": true
      }
    },
    {
      "id": "S08_slow_network",
      "description": "Desktop but slow network (2G/Edge)",
      "config": {
        "starCount": 80,
        "nebulaCount": 0,
        "enableConstellations": false,
        "enableNebulae": false,
        "shootingStarInterval": 12000,
        "scripts_defer": true,
        "critical_css_inline": true
      }
    }
  ],
  "assertions": [
    {
      "id": "A01_scripts_defer",
      "description": "All non-module scripts have defer attribute",
      "type": "programmatic",
      "check": "grep -c 'defer' index.html >= 4",
      "universal": true
    },
    {
      "id": "A02_no_console_log",
      "description": "No console.log in production modules",
      "type": "programmatic",
      "check": "grep -rc 'console.log' modules/ == 0",
      "universal": true
    },
    {
      "id": "A03_lazy_loading",
      "description": "Below-fold images have loading=lazy",
      "type": "programmatic",
      "check": "grep -c 'loading=\"lazy\"' index.html >= 8",
      "universal": true
    },
    {
      "id": "A04_font_display_swap",
      "description": "Google Fonts use display=swap",
      "type": "programmatic",
      "check": "grep -c 'display=swap' index.html >= 2",
      "universal": true
    },
    {
      "id": "A05_preconnect",
      "description": "Preconnect hints for external origins",
      "type": "programmatic",
      "check": "grep -c 'rel=\"preconnect\"' index.html >= 3",
      "universal": true
    },
    {
      "id": "A06_visibility_pause",
      "description": "Canvas pauses on tab hidden (visibilitychange)",
      "type": "programmatic",
      "check": "grep -c 'visibilitychange' modules/stellar-engine.js >= 1",
      "universal": true
    },
    {
      "id": "A07_reduced_motion",
      "description": "Respects prefers-reduced-motion",
      "type": "programmatic",
      "check": "grep -c 'prefers-reduced-motion' modules/stellar-engine.js >= 1",
      "universal": true
    },
    {
      "id": "A08_mobile_particle_reduction",
      "description": "Mobile devices get fewer particles",
      "type": "programmatic",
      "check": "grep -c 'isMobile' modules/advanced-animations.js >= 1",
      "universal": true
    },
    {
      "id": "A09_cache_headers",
      "description": "Netlify cache headers configured for static assets",
      "type": "programmatic",
      "check": "test -f netlify.toml && grep -c 'Cache-Control' netlify.toml >= 2",
      "universal": true
    },
    {
      "id": "A10_js_syntax_valid",
      "description": "All JS modules pass node --check",
      "type": "programmatic",
      "check": "for f in modules/*.js; do node --check $f || exit 1; done",
      "universal": true
    },
    {
      "id": "A11_no_dead_code",
      "description": "No legacy dead functions left in modules",
      "type": "programmatic",
      "check": "grep -c 'initializeParticles' modules/advanced-animations.js == 0",
      "universal": true
    },
    {
      "id": "A12_image_dimensions",
      "description": "Profile image has width/height to prevent CLS",
      "type": "programmatic",
      "check": "grep -c 'width=\"440\" height=\"566\"' index.html >= 1",
      "universal": true
    },
    {
      "id": "A13_critical_css_inline",
      "description": "Critical CSS inlined in head for instant first paint",
      "type": "programmatic",
      "check": "grep -c '<style>' index.html >= 1",
      "universal": true
    },
    {
      "id": "A14_image_optimized",
      "description": "Profile image compressed (optimized version used)",
      "type": "programmatic",
      "check": "grep -c 'Artillio-optimized' index.html >= 1",
      "universal": true
    },
    {
      "id": "A15_logo_optimized",
      "description": "Logo/favicon uses optimized version",
      "type": "programmatic",
      "check": "grep -c 'logo-optimized' index.html >= 1",
      "universal": true
    },
    {
      "id": "A16_requestIdleCallback",
      "description": "Stellar engine deferred via requestIdleCallback",
      "type": "programmatic",
      "check": "grep -c 'requestIdleCallback' index.html >= 1",
      "universal": true
    },
    {
      "id": "A17_security_headers",
      "description": "Security headers configured in netlify.toml",
      "type": "programmatic",
      "check": "grep -c 'X-Frame-Options' netlify.toml >= 1",
      "universal": true
    },
    {
      "id": "A18_no_duplicate_keyframes",
      "description": "No duplicate fadeIn keyframes in CSS",
      "type": "programmatic",
      "check": "grep -c '@keyframes fadeIn {' styles/style.css == 1",
      "universal": true
    },
    {
      "id": "A19_services_lazy",
      "description": "Service section images have lazy loading",
      "type": "programmatic",
      "check": "grep -c 'loading=\"lazy\"' index.html >= 12",
      "universal": true
    }
  ]
}
