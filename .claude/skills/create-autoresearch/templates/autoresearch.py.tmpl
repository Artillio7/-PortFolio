# --- Helpers ------------------------------------------------------------------


def load_state() -> dict:
    if STATE_FILE.exists():
        try:
            text = STATE_FILE.read_text(encoding="utf-8").strip()
            if text:
                return json.loads(text)
        except (json.JSONDecodeError, ValueError):
            print("  WARN: state.json corrupt, reset")
    return {"best_score": -1.0, "run_number": 0}


def save_state(state: dict):
    STATE_FILE.write_text(json.dumps(state, indent=2), encoding="utf-8")


def load_prompt() -> str:
    return SKILL_PROMPT_FILE.read_text(encoding="utf-8").strip()


def save_prompt(prompt: str):
    SKILL_PROMPT_FILE.write_text(prompt, encoding="utf-8")


def _claude_cli(prompt: str, timeout: int = 120) -> str | None:
    """Call Claude Code CLI and return text output."""
    try:
        result = subprocess.run(
            ["claude", "-p", "-", "--output-format", "text"],
            input=prompt, capture_output=True, text=True,
            encoding="utf-8", errors="replace", timeout=timeout,
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip()
        if result.stderr:
            print(f"    CLI stderr: {result.stderr[:200]}")
        return None
    except subprocess.TimeoutExpired:
        print(f"    CLI: timeout after {timeout}s")
        return None
    except Exception as e:
        print(f"    CLI ERROR: {e}")
        return None


def _extract_json(text: str) -> dict | None:
    """Extract JSON object from a response (handles markdown fences)."""
    if "```" in text:
        text = text.split("```")[1]
        if text.startswith("json"):
            text = text[4:]
        text = text.strip()
    start = text.find("{")
    end = text.rfind("}")
    if start >= 0 and end > start:
        try:
            return json.loads(text[start:end + 1])
        except json.JSONDecodeError:
            pass
    return None


