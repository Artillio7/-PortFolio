# --- Auto-installation des dependances ----------------------------------------

def _ensure_deps():
    missing = []
    for module, pip_name in {"dotenv": "python-dotenv"}.items():
        try:
            __import__(module)
        except ImportError:
            missing.append(pip_name)
    if missing:
        print(f"  Installation: {', '.join(missing)}")
        subprocess.check_call(
            [sys.executable, "-m", "pip", "install", "--quiet", *missing],
            stdout=subprocess.DEVNULL,
        )

_ensure_deps()

